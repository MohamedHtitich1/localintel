# History files
.Rhistory
.Rapp.history

# Session Data files
.RData
.RDataTmp

# User-specific files
.Ruserdata

# Example code in package build process
*-Ex.R

# Output files from R CMD build
/*.tar.gz

# Output files from R CMD check
/*.Rcheck/

# RStudio files
.Rproj.user/

# produced vignettes
vignettes/*.html
vignettes/*.pdf

# OAuth2 token, see https://github.com/hadley/httr/releases/tag/v0.3
.httr-oauth

# knitr and R markdown default cache directories
*_cache/
/cache/

# Temporary files created by R markdown
*.utf8.md
*.knit.md

# R Environment Variables
.Renviron

# pkgdown site
docs/

# translation temp files
po/*~

# RStudio Connect folder
rsconnect/

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Local development
.DS_Store
Thumbs.db

# Large data files (cached results, not source code)
tests/dhs-profile-results/*.rds
tests/gapfill-results/*.rds
tests/gapfill-results/*.pdf
tests/gapfill-results/*.geojson
tests/gapfill-results/*.json
tests/gapfill-results/gadm_cache/
webapp/data/*.rds
webapp/data/*.geojson
webapp/data/*.csv.gz

# Generated dashboard (4+ MB, regenerate with generate_dashboard.py)
webapp/frontend/index.html

# Webapp environment
webapp/.env
