\name{dhs_hiv_codes}
\alias{dhs_hiv_codes}
\title{DHS HIV/AIDS Indicator Codes}
\description{
Returns a named vector of DHS indicator IDs for HIV/AIDS prevalence,
testing, knowledge, and treatment.
}
\usage{
dhs_hiv_codes()
}
\value{
Named character vector of DHS indicator IDs.
}
\examples{
\dontrun{
codes <- dhs_hiv_codes()
names(codes)
}
}
\keyword{indicators}
