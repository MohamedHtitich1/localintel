\name{dhs_mortality_codes}
\alias{dhs_mortality_codes}
\title{DHS Mortality Indicator Codes}
\description{
Returns a named vector of DHS indicator IDs for child and infant mortality.
Covers under-5, infant, neonatal, and perinatal mortality rates.
}
\usage{
dhs_mortality_codes()
}
\value{
Named character vector of DHS indicator IDs.
}
\examples{
\dontrun{
codes <- dhs_mortality_codes()
names(codes)
}
}
\keyword{indicators}
