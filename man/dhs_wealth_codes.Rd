\name{dhs_wealth_codes}
\alias{dhs_wealth_codes}
\title{DHS Wealth and Asset Indicator Codes}
\description{
Returns a named vector of DHS indicator IDs for household wealth
and asset ownership. Covers wealth quintile distribution and
key asset indicators.
}
\usage{
dhs_wealth_codes()
}
\value{
Named character vector of DHS indicator IDs.
}
\examples{
\dontrun{
codes <- dhs_wealth_codes()
names(codes)
}
}
\keyword{indicators}
