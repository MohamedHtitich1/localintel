\name{dhs_education_codes}
\alias{dhs_education_codes}
\title{DHS Education Indicator Codes}
\description{
Returns a named vector of DHS indicator IDs for education and
literacy. Covers literacy rates, school attendance, and educational
attainment for women and men.
}
\usage{
dhs_education_codes()
}
\value{
Named character vector of DHS indicator IDs.
}
\examples{
\dontrun{
codes <- dhs_education_codes()
names(codes)
}
}
\keyword{indicators}
