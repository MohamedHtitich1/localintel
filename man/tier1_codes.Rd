\name{tier1_codes}
\alias{tier1_codes}
\title{Tier 1 DHS Country Codes}
\description{
Returns a character vector of 15 Tier 1 validation countries for the
SSA expansion. These countries have 5+ survey rounds and represent
approximately 70\% of SSA population.
}
\usage{
tier1_codes()
}
\value{
Character vector of 15 DHS country codes.
}
\examples{
\dontrun{
tier1_codes()
}
}
\keyword{datasets}
