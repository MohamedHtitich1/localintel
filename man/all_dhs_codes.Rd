\name{all_dhs_codes}
\alias{all_dhs_codes}
\title{All DHS Indicator Codes}
\description{
Returns a comprehensive named vector combining indicator codes from
all 8 DHS thematic domains. This is the full registry of DHS
subnational indicators that localintel can process.
}
\usage{
all_dhs_codes()
}
\value{
Named character vector of all DHS indicator IDs.
}
\examples{
\dontrun{
all_codes <- all_dhs_codes()
length(all_codes)
}
}
\keyword{indicators}
