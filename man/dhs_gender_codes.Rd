\name{dhs_gender_codes}
\alias{dhs_gender_codes}
\title{DHS Gender Indicator Codes}
\description{
Returns a named vector of DHS indicator IDs for gender-related
indicators. Covers women's earnings autonomy, domestic violence
experience, and attitudes towards wife-beating.
}
\usage{
dhs_gender_codes()
}
\value{
Named character vector of DHS indicator IDs.
}
\examples{
\dontrun{
codes <- dhs_gender_codes()
names(codes)
}
}
\keyword{indicators}
